<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Academy Entry Form</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="form-container">
        <div class="header-table">
            <div class="logo-box">
                <div class="logo-placeholder">[LOGO]</div>
            </div>
            <div class="title-box">
                <h1>ACADEMY ENTRY FORM</h1>
                <h3>Application for Admission</h3>
                <p><i>Please fill in the form in BLOCK LETTERS and submit all required documents.</i></p>
            </div>
            <div class="photo-box">
                Paste Passport Size Photograph Here
            </div>
        </div>

        <form>
            <div class="section-title">1. CLASS APPLIED FOR</div>
            <div class="form-group">
                <label>Academic Year:</label> <input type="text" style="width: 20%;">
                <label>Class Applying For:</label> <input type="text" style="width: 25%;">
                <label>Date of Admission Required:</label> <input type="text" placeholder="DD/MM/YYYY" style="width: 15%;">
            </div>
            <div class="form-group">
                <label>Grade/Stream (if applicable):</label> <input type="text" style="width: 70%;">
            </div>

            <div class="section-title">2. STUDENT INFORMATION</div>
            <div class="form-group">
                <label>Full Name (as per Birth Certificate):</label> <input type="text" style="width: 73%;">
            </div>
            <div class="form-group">
                <label>Date of Birth (DD/MM/YYYY):</label> <input type="text" style="width: 15%;">
                <label style="margin-left:20px;">Gender:</label>
                <input type="checkbox"> Male
                <input type="checkbox"> Female
                <input type="checkbox"> Other
            </div>
            <div class="form-group">
                <label>Nationality:</label> <input type="text" style="width: 25%;">
                <label>Religion:</label> <input type="text" style="width: 20%;">
                <label>Mother Tongue:</label> <input type="text" style="width: 20%;">
            </div>
            <div class="form-group">
                <label>Aadhaar Number / ID (if any):</label> <input type="text" style="width: 40%;">
                <label>Blood Group:</label> <input type="text" style="width: 30%;">
            </div>
            <div class="form-group">
                <label>Place of Birth:</label> <input type="text" style="width: 25%;">
                <label>State:</label> <input type="text" style="width: 25%;">
                <label>Country:</label> <input type="text" style="width: 20%;">
            </div>
            <div class="form-group">
                <label>Student's Residential Address:</label>
                <input type="text" style="width: 98%; margin-top: 5px;">
                <input type="text" style="width: 98%; margin-top: 5px;">
            </div>
            <div class="form-group">
                <label>City:</label> <input type="text" style="width: 25%;">
                <label>State:</label> <input type="text" style="width: 25%;">
                <label>PIN Code:</label> <input type="text" style="width: 20%;">
            </div>
            <div class="form-group">
                <label>Phone Number:</label> <input type="text" style="width: 35%;">
                <label>Email (if any):</label> <input type="text" style="width: 40%;">
            </div>

            <div class="section-title">3. PARENT / GUARDIAN INFORMATION</div>
            <table class="parent-table">
                <tr>
                    <th>FATHER / GUARDIAN</th>
                    <th>MOTHER / GUARDIAN</th>
                </tr>
                <tr>
                    <td>
                        <label>Full Name:</label> <input type="text"><br>
                        <label>Qualification:</label> <input type="text"><br>
                        <label>Occupation:</label> <input type="text"><br>
                        <label>Organization/Company:</label> <input type="text"><br>
                        <label>Phone Number:</label> <input type="text"><br>
                        <label>Email (if any):</label> <input type="text"><br>
                        <label>Annual Income (Approx.): ₹</label> <input type="text" style="width: 50%;">
                    </td>
                    <td>
                        <label>Full Name:</label> <input type="text"><br>
                        <label>Qualification:</label> <input type="text"><br>
                        <label>Occupation:</label> <input type="text"><br>
                        <label>Organization/Company:</label> <input type="text"><br>
                        <label>Phone Number:</label> <input type="text"><br>
                        <label>Email (if any):</label> <input type="text"><br>
                        <label>Parent/Guardian Signature:</label> <input type="text" style="width: 50%; margin-top:15px;">
                    </td>
                </tr>
            </table>

            <div class="section-title">4. PREVIOUS SCHOOL DETAILS</div>
            <div class="form-group">
                <label>Previous School Name:</label> <input type="text" style="width: 50%;">
                <label>Board:</label> <input type="text" style="width: 20%;">
            </div>
            <div class="form-group">
                <label>Last Class Studied:</label> <input type="text" style="width: 30%;">
                <label>Academic Year:</label> <input type="text" style="width: 30%;">
            </div>
            <div class="form-group">
                <label>City:</label> <input type="text" style="width: 25%;">
                <label>State:</label> <input type="text" style="width: 25%;">
                <label>Country:</label> <input type="text" style="width: 20%;">
            </div>

            <div class="section-title">5. ADDITIONAL INFORMATION</div>
            <div class="form-group">
                <label>Does the student have any medical condition / allergy?</label>
                <input type="checkbox"> Yes <input type="checkbox"> No 
                <label style="margin-left: 10px;">If Yes, please specify:</label> <input type="text" style="width: 35%;">
            </div>
            <div class="form-group">
                <label>Has the student been involved in any disciplinary action?</label>
                <input type="checkbox"> Yes <input type="checkbox"> No 
                <label style="margin-left: 10px;">If Yes, please specify:</label> <input type="text" style="width: 35%;">
            </div>
            <div class="form-group">
                <label>Hobbies / Interests:</label> <input type="text" style="width: 75%;">
            </div>

            <div class="section-title">6. DOCUMENTS CHECKLIST (Please tick)</div>
            <table class="checklist-table">
                <tr>
                    <td><input type="checkbox"> Birth Certificate</td>
                    <td><input type="checkbox"> Passport Size Photographs</td>
                    <td><input type="checkbox"> Previous School Report Card</td>
                </tr>
                <tr>
                    <td><input type="checkbox"> Transfer Certificate</td>
                    <td><input type="checkbox"> Address Proof</td>
                    <td><input type="checkbox"> ID Proof (Aadhaar/Passport, etc.)</td>
                </tr>
                <tr>
                    <td><input type="checkbox"> Medical Certificate (if applicable)</td>
                    <td colspan="2"><input type="checkbox"> Others (Please specify): <input type="text" style="width: 60%;"></td>
                </tr>
            </table>

            <div class="section-title">7. DECLARATION</div>
            <div class="declaration-box">
                <p>I hereby declare that the information provided above is true and correct to the best of my knowledge and belief. I understand that any false information may lead to cancellation of admission.</p>
                <br>
                <label>Date:</label> <input type="text" placeholder="  /  /  " style="width: 15%;">
                <label style="margin-left: 150px;">Signature of Parent / Guardian:</label> <input type="text" style="width: 40%;">
            </div>

            <div class="office-title">FOR OFFICE USE ONLY</div>
            <div class="office-box">
                <div class="form-group">
                    <label>Application No.:</label> <input type="text" style="width: 20%;">
                    <label>Date Received:</label> <input type="text" placeholder="  /  /  " style="width: 15%;">
                    <label>Received By:</label> <input type="text" style="width: 25%;">
                </div>
                <div class="form-group">
                    <label>Documents Verified:</label> <input type="checkbox"> Yes <input type="checkbox"> No
                    <label style="margin-left: 30px;">Admission Approved:</label> <input type="checkbox"> Yes <input type="checkbox"> No
                    <label style="margin-left: 30px;">Remarks:</label> <input type="text" style="width: 20%;">
                </div>
            </div>
        </form>
    </div>

</body>
</html>
